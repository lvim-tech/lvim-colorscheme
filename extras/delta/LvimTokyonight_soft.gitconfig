[delta]
    syntax-theme = LvimTokyonight_soft
    side-by-side = false
    navigate = true
    hyperlinks = true
    keep-plus-minus-markers = false
    zero-style = syntax
    file-added-label = [+]
    file-copied-label = [==]
    file-modified-label = [*]
    file-removed-label = [-]
    file-renamed-label = [->]
    line-numbers = true
    line-numbers-left-format = "{nm:>1} "
    line-numbers-right-format = "{np:>1} "
    blame-code-style = syntax 
    blame-format = "{author:<18} ({commit:>7}) {timestamp:^16} "
    merge-conflict-begin-symbol = ⌃
    merge-conflict-end-symbol = ⌄
    merge-conflict-ours-diff-header-decoration-style = ''
    merge-conflict-theirs-diff-header-decoration-style = ''

    file-style = omit "#9470d5"
    commit-decoration-style = "#8359ce" ol
    commit-style = raw
    blame-separator-style = "#63677c"
    hunk-header-decoration-style = "#dd8b5a" ul
    hunk-header-file-style = "#9dbd7b"
    hunk-header-line-number-style = "#8fb468"
    hunk-header-style = file line-number syntax bold italic
    minus-style = syntax "#2e2533"
    minus-non-emph-style = syntax "#2e2533"
    minus-emph-style = syntax "#40194f"
    minus-empty-line-marker-style = syntax "#2e2533"
    line-numbers-minus-style = "#d76479"
    plus-style = syntax "#292d33"
    plus-non-emph-style = syntax "#292d33"
    plus-emph-style = syntax "#1b3047"
    plus-empty-line-marker-style = syntax "#292d33"
    line-numbers-plus-style = "#9dbd7b"
    line-numbers-zero-style = "#b2b6c7"
    whitespace-error-style = "#9381b3"
    merge-conflict-ours-diff-header-style = "#c5a06b" bold
    merge-conflict-theirs-diff-header-style = "#bd9357" bold overline
    map-styles = \
        bold purple => syntax "#1b1b24", \
        bold blue => syntax "#181820", \
        bold cyan => syntax "#282d42", \
        bold yellow => syntax "#2d3349"
    zero-style = syntax