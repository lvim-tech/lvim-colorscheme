{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme KanagawaDark",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme KanagawaDark",
      "appearance": "dark",
      "style": {
        "background": "#1b1c21",
        "editor.background": "#17181c",
        "editor.foreground": "#54546d",
        "editor.line_number": "#4b4b61",
        "editor.active_line_number": "#5d5d79",
        "editor.active_line.background": "#202127",
        "editor.gutter.background": "#17181c",
        "text": "#54546d",
        "text.muted": "#51515b",
        "text.accent": "#4d699b",
        "border": "#25262d",
        "surface.background": "#17181c",
        "elevated_surface.background": "#17181c",
        "element.background": "#202127",
        "element.hover": "#25262d",
        "element.selected": "#25262d",
        "ghost_element.hover": "#25262d",
        "drop_target.background": "#25262d",
        "status_bar.background": "#202127",
        "title_bar.background": "#202127",
        "toolbar.background": "#17181c",
        "tab_bar.background": "#202127",
        "tab.active_background": "#17181c",
        "tab.inactive_background": "#202127",
        "panel.background": "#202127",
        "scrollbar.thumb.background": "#25262d",
        "terminal.background": "#17181c",
        "terminal.foreground": "#54546d",
        "terminal.ansi.black": "#1a1a1f",
        "terminal.ansi.red": "#b65252",
        "terminal.ansi.green": "#6e8156",
        "terminal.ansi.yellow": "#e0c286",
        "terminal.ansi.blue": "#4a6494",
        "terminal.ansi.magenta": "#c4746e",
        "terminal.ansi.cyan": "#597b75",
        "terminal.ansi.white": "#505067",
        "terminal.ansi.bright_black": "#1c7060",
        "terminal.ansi.bright_red": "#df4848",
        "terminal.ansi.bright_green": "#74914a",
        "terminal.ansi.bright_yellow": "#f6cf79",
        "terminal.ansi.bright_blue": "#4170b8",
        "terminal.ansi.bright_magenta": "#dc7c74",
        "terminal.ansi.bright_cyan": "#508c82",
        "terminal.ansi.bright_white": "#54546d",
        "created": "#5f7240",
        "modified": "#a29512",
        "deleted": "#96271a",
        "error": "#b65252",
        "warning": "#e0c286",
        "info": "#4d699b",
        "hint": "#597b75",
        "syntax": {
          "comment": { "color": "#51515b", "font_style": "italic" },
          "string": { "color": "#6e8156" },
          "string.regex": { "color": "#597b75" },
          "number": { "color": "#c99460" },
          "constant": { "color": "#c99460" },
          "keyword": { "color": "#766b90" },
          "function": { "color": "#4d699b" },
          "function.method": { "color": "#4d699b" },
          "type": { "color": "#e0c286" },
          "variable": { "color": "#54546d" },
          "variable.special": { "color": "#b65252" },
          "property": { "color": "#597b75" },
          "operator": { "color": "#597b75" },
          "punctuation": { "color": "#4b4b61" },
          "tag": { "color": "#b65252" },
          "attribute": { "color": "#597b75" },
          "title": { "color": "#4d699b", "font_weight": 700 },
          "link_uri": { "color": "#597b75" },
          "link_text": { "color": "#b65252" }
        }
      }
    }
  ]
}