{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme MaterialLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme MaterialLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#7a8990",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#7a8990",
        "text.accent": "#3c62a8",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#a9484d",
        "terminal.ansi.green": "#5f7541",
        "terminal.ansi.yellow": "#8b6d37",
        "terminal.ansi.blue": "#436fcb",
        "terminal.ansi.magenta": "#b44356",
        "terminal.ansi.cyan": "#407e97",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#89b9c3",
        "terminal.ansi.bright_red": "#d03e48",
        "terminal.ansi.bright_green": "#658431",
        "terminal.ansi.bright_yellow": "#a0781a",
        "terminal.ansi.bright_blue": "#237af9",
        "terminal.ansi.bright_magenta": "#db3558",
        "terminal.ansi.bright_cyan": "#208eb0",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#5f7541",
        "modified": "#8b6d37",
        "deleted": "#a9484d",
        "error": "#a9484d",
        "warning": "#8b6d37",
        "info": "#3c62a8",
        "hint": "#407e97",
        "syntax": {
          "comment": { "color": "#7a8990", "font_style": "italic" },
          "string": { "color": "#5f7541" },
          "string.regex": { "color": "#407e97" },
          "number": { "color": "#c77259" },
          "constant": { "color": "#c77259" },
          "keyword": { "color": "#6f567f" },
          "function": { "color": "#3c62a8" },
          "function.method": { "color": "#3c62a8" },
          "type": { "color": "#8b6d37" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#a9484d" },
          "property": { "color": "#407e97" },
          "operator": { "color": "#407e97" },
          "punctuation": { "color": "#7a8990" },
          "tag": { "color": "#a9484d" },
          "attribute": { "color": "#407e97" },
          "title": { "color": "#3c62a8", "font_weight": 700 },
          "link_uri": { "color": "#407e97" },
          "link_text": { "color": "#a9484d" }
        }
      }
    }
  ]
}