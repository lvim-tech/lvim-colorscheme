{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme DraculaDark",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme DraculaDark",
      "appearance": "dark",
      "style": {
        "background": "#20212a",
        "editor.background": "#1b1d25",
        "editor.foreground": "#c7c7b3",
        "editor.line_number": "#828287",
        "editor.active_line_number": "#c2c2b7",
        "editor.active_line.background": "#242630",
        "editor.gutter.background": "#1b1d25",
        "text": "#c7c7b3",
        "text.muted": "#737a94",
        "text.accent": "#65c8dd",
        "border": "#2c2e3a",
        "surface.background": "#1b1d25",
        "elevated_surface.background": "#1b1d25",
        "element.background": "#242630",
        "element.hover": "#2c2e3a",
        "element.selected": "#2c2e3a",
        "ghost_element.hover": "#2c2e3a",
        "drop_target.background": "#2c2e3a",
        "status_bar.background": "#242630",
        "title_bar.background": "#242630",
        "toolbar.background": "#1b1d25",
        "tab_bar.background": "#242630",
        "tab.active_background": "#1b1d25",
        "tab.inactive_background": "#242630",
        "panel.background": "#242630",
        "scrollbar.thumb.background": "#2c2e3a",
        "terminal.background": "#1b1d25",
        "terminal.foreground": "#c7c7b3",
        "terminal.ansi.black": "#1d1e26",
        "terminal.ansi.red": "#dd5757",
        "terminal.ansi.green": "#58d879",
        "terminal.ansi.yellow": "#d0da68",
        "terminal.ansi.blue": "#4dc0d8",
        "terminal.ansi.magenta": "#dc61a8",
        "terminal.ansi.cyan": "#61dfca",
        "terminal.ansi.white": "#c6c6c3",
        "terminal.ansi.bright_black": "#44475a",
        "terminal.ansi.bright_red": "#f16161",
        "terminal.ansi.bright_green": "#0eed68",
        "terminal.ansi.bright_yellow": "#ddea2f",
        "terminal.ansi.bright_blue": "#00d2f0",
        "terminal.ansi.bright_magenta": "#f269b8",
        "terminal.ansi.bright_cyan": "#07f3d8",
        "terminal.ansi.bright_white": "#c7c7b3",
        "created": "#58d879",
        "modified": "#d0da68",
        "deleted": "#dd5757",
        "error": "#dd5757",
        "warning": "#d0da68",
        "info": "#65c8dd",
        "hint": "#61dfca",
        "syntax": {
          "comment": { "color": "#737a94", "font_style": "italic" },
          "string": { "color": "#58d879" },
          "string.regex": { "color": "#61dfca" },
          "number": { "color": "#de9f5c" },
          "constant": { "color": "#de9f5c" },
          "keyword": { "color": "#9c80c3" },
          "function": { "color": "#65c8dd" },
          "function.method": { "color": "#65c8dd" },
          "type": { "color": "#d0da68" },
          "variable": { "color": "#c7c7b3" },
          "variable.special": { "color": "#dd5757" },
          "property": { "color": "#61dfca" },
          "operator": { "color": "#61dfca" },
          "punctuation": { "color": "#828287" },
          "tag": { "color": "#dd5757" },
          "attribute": { "color": "#61dfca" },
          "title": { "color": "#65c8dd", "font_weight": 700 },
          "link_uri": { "color": "#61dfca" },
          "link_text": { "color": "#dd5757" }
        }
      }
    }
  ]
}