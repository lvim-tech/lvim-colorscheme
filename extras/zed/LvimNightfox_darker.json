{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme NightfoxDarker",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme NightfoxDarker",
      "appearance": "dark",
      "style": {
        "background": "#10161e",
        "editor.background": "#0e131a",
        "editor.foreground": "#bcbdbd",
        "editor.line_number": "#7b8189",
        "editor.active_line_number": "#bcbcbd",
        "editor.active_line.background": "#141c26",
        "editor.gutter.background": "#0e131a",
        "text": "#bcbdbd",
        "text.muted": "#7b8189",
        "text.accent": "#7292bd",
        "border": "#1c2736",
        "surface.background": "#0e131a",
        "elevated_surface.background": "#0e131a",
        "element.background": "#141c26",
        "element.hover": "#1c2736",
        "element.selected": "#1c2736",
        "ghost_element.hover": "#1c2736",
        "drop_target.background": "#1c2736",
        "status_bar.background": "#141c26",
        "title_bar.background": "#141c26",
        "toolbar.background": "#0e131a",
        "tab_bar.background": "#141c26",
        "tab.active_background": "#0e131a",
        "tab.inactive_background": "#141c26",
        "panel.background": "#141c26",
        "scrollbar.thumb.background": "#1c2736",
        "terminal.background": "#0e131a",
        "terminal.foreground": "#bcbdbd",
        "terminal.ansi.black": "#10161e",
        "terminal.ansi.red": "#b46478",
        "terminal.ansi.green": "#89aa9a",
        "terminal.ansi.yellow": "#c1ac71",
        "terminal.ansi.blue": "#5f84b4",
        "terminal.ansi.magenta": "#9b82af",
        "terminal.ansi.cyan": "#75bbbd",
        "terminal.ansi.white": "#b1b5bc",
        "terminal.ansi.bright_black": "#2b3b51",
        "terminal.ansi.bright_red": "#d76383",
        "terminal.ansi.bright_green": "#7ebda0",
        "terminal.ansi.bright_yellow": "#d6b95a",
        "terminal.ansi.bright_blue": "#5192d8",
        "terminal.ansi.bright_magenta": "#b08acd",
        "terminal.ansi.bright_cyan": "#5cced0",
        "terminal.ansi.bright_white": "#bcbdbd",
        "created": "#89aa9a",
        "modified": "#c1ac71",
        "deleted": "#b46478",
        "error": "#b46478",
        "warning": "#c1ac71",
        "info": "#7292bd",
        "hint": "#75bbbd",
        "syntax": {
          "comment": { "color": "#7b8189", "font_style": "italic" },
          "string": { "color": "#89aa9a" },
          "string.regex": { "color": "#75bbbd" },
          "number": { "color": "#d49360" },
          "constant": { "color": "#d49360" },
          "keyword": { "color": "#9380b2" },
          "function": { "color": "#7292bd" },
          "function.method": { "color": "#7292bd" },
          "type": { "color": "#c1ac71" },
          "variable": { "color": "#bcbdbd" },
          "variable.special": { "color": "#b46478" },
          "property": { "color": "#75bbbd" },
          "operator": { "color": "#75bbbd" },
          "punctuation": { "color": "#7b8189" },
          "tag": { "color": "#b46478" },
          "attribute": { "color": "#75bbbd" },
          "title": { "color": "#7292bd", "font_weight": 700 },
          "link_uri": { "color": "#75bbbd" },
          "link_text": { "color": "#b46478" }
        }
      }
    }
  ]
}