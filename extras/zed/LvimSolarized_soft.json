{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme SolarizedSoft",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme SolarizedSoft",
      "appearance": "dark",
      "style": {
        "background": "#002d39",
        "editor.background": "#002832",
        "editor.foreground": "#9da4a4",
        "editor.line_number": "#5f6a6e",
        "editor.active_line_number": "#969e9e",
        "editor.active_line.background": "#003441",
        "editor.gutter.background": "#002832",
        "text": "#9da4a4",
        "text.muted": "#5f6a6e",
        "text.accent": "#4386b5",
        "border": "#084452",
        "surface.background": "#002832",
        "elevated_surface.background": "#002832",
        "element.background": "#003441",
        "element.hover": "#084452",
        "element.selected": "#084452",
        "ghost_element.hover": "#084452",
        "drop_target.background": "#084452",
        "status_bar.background": "#003441",
        "title_bar.background": "#003441",
        "toolbar.background": "#002832",
        "tab_bar.background": "#003441",
        "tab.active_background": "#002832",
        "tab.inactive_background": "#003441",
        "panel.background": "#003441",
        "scrollbar.thumb.background": "#084452",
        "terminal.background": "#002832",
        "terminal.foreground": "#9da4a4",
        "terminal.ansi.black": "#002a34",
        "terminal.ansi.red": "#bf4e4c",
        "terminal.ansi.green": "#727f1a",
        "terminal.ansi.yellow": "#96791f",
        "terminal.ansi.blue": "#3d7aa5",
        "terminal.ansi.magenta": "#b75283",
        "terminal.ansi.cyan": "#3e8d87",
        "terminal.ansi.white": "#6c777b",
        "terminal.ansi.bright_black": "#0a3f4c",
        "terminal.ansi.bright_red": "#e7433f",
        "terminal.ansi.bright_green": "#7e8d00",
        "terminal.ansi.bright_yellow": "#a78500",
        "terminal.ansi.bright_blue": "#1589c3",
        "terminal.ansi.bright_magenta": "#df4597",
        "terminal.ansi.bright_cyan": "#109e96",
        "terminal.ansi.bright_white": "#9da4a4",
        "created": "#727f1a",
        "modified": "#96791f",
        "deleted": "#bf4e4c",
        "error": "#bf4e4c",
        "warning": "#96791f",
        "info": "#4386b5",
        "hint": "#3e8d87",
        "syntax": {
          "comment": { "color": "#5f6a6e", "font_style": "italic" },
          "string": { "color": "#727f1a" },
          "string.regex": { "color": "#3e8d87" },
          "number": { "color": "#ac5835" },
          "constant": { "color": "#ac5835" },
          "keyword": { "color": "#8385a2" },
          "function": { "color": "#4386b5" },
          "function.method": { "color": "#4386b5" },
          "type": { "color": "#96791f" },
          "variable": { "color": "#9da4a4" },
          "variable.special": { "color": "#bf4e4c" },
          "property": { "color": "#3e8d87" },
          "operator": { "color": "#3e8d87" },
          "punctuation": { "color": "#5f6a6e" },
          "tag": { "color": "#bf4e4c" },
          "attribute": { "color": "#3e8d87" },
          "title": { "color": "#4386b5", "font_weight": 700 },
          "link_uri": { "color": "#3e8d87" },
          "link_text": { "color": "#bf4e4c" }
        }
      }
    }
  ]
}