{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme KanagawaLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme KanagawaLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#a3a3b1",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#9e9ea4",
        "text.accent": "#6386c4",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#c85b5b",
        "terminal.ansi.green": "#677951",
        "terminal.ansi.yellow": "#776745",
        "terminal.ansi.blue": "#688bcb",
        "terminal.ansi.magenta": "#92534e",
        "terminal.ansi.cyan": "#5d807a",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#2a9b86",
        "terminal.ansi.bright_red": "#e26060",
        "terminal.ansi.bright_green": "#6d8946",
        "terminal.ansi.bright_yellow": "#8a7339",
        "terminal.ansi.bright_blue": "#6b98e6",
        "terminal.ansi.bright_magenta": "#b65248",
        "terminal.ansi.bright_cyan": "#549187",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#748a4f",
        "modified": "#988b10",
        "deleted": "#f57d76",
        "error": "#c85b5b",
        "warning": "#776745",
        "info": "#6386c4",
        "hint": "#5d807a",
        "syntax": {
          "comment": { "color": "#9e9ea4", "font_style": "italic" },
          "string": { "color": "#677951" },
          "string.regex": { "color": "#5d807a" },
          "number": { "color": "#a5794e" },
          "constant": { "color": "#a5794e" },
          "keyword": { "color": "#82789b" },
          "function": { "color": "#6386c4" },
          "function.method": { "color": "#6386c4" },
          "type": { "color": "#776745" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#c85b5b" },
          "property": { "color": "#5d807a" },
          "operator": { "color": "#5d807a" },
          "punctuation": { "color": "#a3a3b1" },
          "tag": { "color": "#c85b5b" },
          "attribute": { "color": "#5d807a" },
          "title": { "color": "#6386c4", "font_weight": 700 },
          "link_uri": { "color": "#5d807a" },
          "link_text": { "color": "#c85b5b" }
        }
      }
    }
  ]
}