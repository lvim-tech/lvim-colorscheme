{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme CatppuccinLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme CatppuccinLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#62656f",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#777984",
        "text.accent": "#5d8bd3",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#9d445e",
        "terminal.ansi.green": "#557f51",
        "terminal.ansi.yellow": "#7f6c41",
        "terminal.ansi.blue": "#416cb1",
        "terminal.ansi.magenta": "#c065a9",
        "terminal.ansi.cyan": "#487d86",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#9fa2b2",
        "terminal.ansi.bright_red": "#c23a68",
        "terminal.ansi.bright_green": "#4d9045",
        "terminal.ansi.bright_yellow": "#927830",
        "terminal.ansi.bright_blue": "#2678d9",
        "terminal.ansi.bright_magenta": "#e161c3",
        "terminal.ansi.bright_cyan": "#358d9a",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#557f51",
        "modified": "#7f6c41",
        "deleted": "#9d445e",
        "error": "#9d445e",
        "warning": "#7f6c41",
        "info": "#5d8bd3",
        "hint": "#487d86",
        "syntax": {
          "comment": { "color": "#777984", "font_style": "italic" },
          "string": { "color": "#557f51" },
          "string.regex": { "color": "#487d86" },
          "number": { "color": "#aa724e" },
          "constant": { "color": "#aa724e" },
          "keyword": { "color": "#734e98" },
          "function": { "color": "#5d8bd3" },
          "function.method": { "color": "#5d8bd3" },
          "type": { "color": "#7f6c41" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#9d445e" },
          "property": { "color": "#487d86" },
          "operator": { "color": "#487d86" },
          "punctuation": { "color": "#62656f" },
          "tag": { "color": "#9d445e" },
          "attribute": { "color": "#487d86" },
          "title": { "color": "#5d8bd3", "font_weight": 700 },
          "link_uri": { "color": "#487d86" },
          "link_text": { "color": "#9d445e" }
        }
      }
    }
  ]
}