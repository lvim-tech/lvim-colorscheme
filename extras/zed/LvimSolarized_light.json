{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme SolarizedLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme SolarizedLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#7b888e",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#7b888e",
        "text.accent": "#39739c",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#cc5452",
        "terminal.ansi.green": "#707c19",
        "terminal.ansi.yellow": "#896f1c",
        "terminal.ansi.blue": "#407fac",
        "terminal.ansi.magenta": "#bd5588",
        "terminal.ansi.cyan": "#347873",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#36cbef",
        "terminal.ansi.bright_red": "#ea5552",
        "terminal.ansi.bright_green": "#7c8a00",
        "terminal.ansi.bright_yellow": "#9a7b00",
        "terminal.ansi.bright_blue": "#168ecb",
        "terminal.ansi.bright_magenta": "#e6479c",
        "terminal.ansi.bright_cyan": "#0d8882",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#707c19",
        "modified": "#896f1c",
        "deleted": "#cc5452",
        "error": "#cc5452",
        "warning": "#896f1c",
        "info": "#39739c",
        "hint": "#347873",
        "syntax": {
          "comment": { "color": "#7b888e", "font_style": "italic" },
          "string": { "color": "#707c19" },
          "string.regex": { "color": "#347873" },
          "number": { "color": "#c3643d" },
          "constant": { "color": "#c3643d" },
          "keyword": { "color": "#626587" },
          "function": { "color": "#39739c" },
          "function.method": { "color": "#39739c" },
          "type": { "color": "#896f1c" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#cc5452" },
          "property": { "color": "#347873" },
          "operator": { "color": "#347873" },
          "punctuation": { "color": "#7b888e" },
          "tag": { "color": "#cc5452" },
          "attribute": { "color": "#347873" },
          "title": { "color": "#39739c", "font_weight": 700 },
          "link_uri": { "color": "#347873" },
          "link_text": { "color": "#cc5452" }
        }
      }
    }
  ]
}