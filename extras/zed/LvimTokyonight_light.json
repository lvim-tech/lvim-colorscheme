{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme TokyonightLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme TokyonightLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#878b9e",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#82859a",
        "text.accent": "#4363a3",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#a94357",
        "terminal.ansi.green": "#667b4f",
        "terminal.ansi.yellow": "#95784f",
        "terminal.ansi.blue": "#4971c5",
        "terminal.ansi.magenta": "#8051c9",
        "terminal.ansi.cyan": "#4682a5",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#a8aecb",
        "terminal.ansi.bright_red": "#cf375b",
        "terminal.ansi.bright_green": "#6b8b43",
        "terminal.ansi.bright_yellow": "#ab833f",
        "terminal.ansi.bright_blue": "#2f7cf3",
        "terminal.ansi.bright_magenta": "#9255eb",
        "terminal.ansi.bright_cyan": "#2892c1",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#667b4f",
        "modified": "#95784f",
        "deleted": "#a94357",
        "error": "#a94357",
        "warning": "#95784f",
        "info": "#4363a3",
        "hint": "#4682a5",
        "syntax": {
          "comment": { "color": "#82859a", "font_style": "italic" },
          "string": { "color": "#667b4f" },
          "string.regex": { "color": "#4682a5" },
          "number": { "color": "#b57148" },
          "constant": { "color": "#b57148" },
          "keyword": { "color": "#715a95" },
          "function": { "color": "#4363a3" },
          "function.method": { "color": "#4363a3" },
          "type": { "color": "#95784f" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#a94357" },
          "property": { "color": "#4682a5" },
          "operator": { "color": "#4682a5" },
          "punctuation": { "color": "#878b9e" },
          "tag": { "color": "#a94357" },
          "attribute": { "color": "#4682a5" },
          "title": { "color": "#4363a3", "font_weight": 700 },
          "link_uri": { "color": "#4682a5" },
          "link_text": { "color": "#a94357" }
        }
      }
    }
  ]
}