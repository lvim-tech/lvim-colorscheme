{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme DraculaLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme DraculaLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#6b6b71",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#6c728b",
        "text.accent": "#3a7885",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#ba4040",
        "terminal.ansi.green": "#2f7a42",
        "terminal.ansi.yellow": "#60652c",
        "terminal.ansi.blue": "#307f90",
        "terminal.ansi.magenta": "#9f3d77",
        "terminal.ansi.cyan": "#2d7065",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#a6a9ba",
        "terminal.ansi.bright_red": "#e13030",
        "terminal.ansi.bright_green": "#078b3a",
        "terminal.ansi.bright_yellow": "#6c7310",
        "terminal.ansi.bright_blue": "#008fa4",
        "terminal.ansi.bright_magenta": "#c32d8d",
        "terminal.ansi.bright_cyan": "#028071",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#2f7a42",
        "modified": "#60652c",
        "deleted": "#ba4040",
        "error": "#ba4040",
        "warning": "#60652c",
        "info": "#3a7885",
        "hint": "#2d7065",
        "syntax": {
          "comment": { "color": "#6c728b", "font_style": "italic" },
          "string": { "color": "#2f7a42" },
          "string.regex": { "color": "#2d7065" },
          "number": { "color": "#9e703f" },
          "constant": { "color": "#9e703f" },
          "keyword": { "color": "#75519f" },
          "function": { "color": "#3a7885" },
          "function.method": { "color": "#3a7885" },
          "type": { "color": "#60652c" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#ba4040" },
          "property": { "color": "#2d7065" },
          "operator": { "color": "#2d7065" },
          "punctuation": { "color": "#6b6b71" },
          "tag": { "color": "#ba4040" },
          "attribute": { "color": "#2d7065" },
          "title": { "color": "#3a7885", "font_weight": 700 },
          "link_uri": { "color": "#2d7065" },
          "link_text": { "color": "#ba4040" }
        }
      }
    }
  ]
}