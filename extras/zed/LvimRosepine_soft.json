{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme RosepineSoft",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme RosepineSoft",
      "appearance": "dark",
      "style": {
        "background": "#242134",
        "editor.background": "#141321",
        "editor.foreground": "#b4b2c7",
        "editor.line_number": "#73717f",
        "editor.active_line_number": "#b8b5c4",
        "editor.active_line.background": "#1e1b2b",
        "editor.gutter.background": "#141321",
        "text": "#b4b2c7",
        "text.muted": "#73717f",
        "text.accent": "#416d7f",
        "border": "#2d2a3b",
        "surface.background": "#141321",
        "elevated_surface.background": "#141321",
        "element.background": "#1e1b2b",
        "element.hover": "#2d2a3b",
        "element.selected": "#2d2a3b",
        "ghost_element.hover": "#2d2a3b",
        "drop_target.background": "#2d2a3b",
        "status_bar.background": "#1e1b2b",
        "title_bar.background": "#1e1b2b",
        "toolbar.background": "#141321",
        "tab_bar.background": "#1e1b2b",
        "tab.active_background": "#141321",
        "tab.inactive_background": "#1e1b2b",
        "panel.background": "#1e1b2b",
        "scrollbar.thumb.background": "#2d2a3b",
        "terminal.background": "#141321",
        "terminal.foreground": "#b4b2c7",
        "terminal.ansi.black": "#181622",
        "terminal.ansi.red": "#cd6985",
        "terminal.ansi.green": "#83b2ba",
        "terminal.ansi.yellow": "#d6a765",
        "terminal.ansi.blue": "#3b6374",
        "terminal.ansi.magenta": "#9f80c4",
        "terminal.ansi.cyan": "#83b2ba",
        "terminal.ansi.white": "#9694a3",
        "terminal.ansi.bright_black": "#312f44",
        "terminal.ansi.bright_red": "#e57091",
        "terminal.ansi.bright_green": "#74c4d0",
        "terminal.ansi.bright_yellow": "#f0b246",
        "terminal.ansi.bright_blue": "#2d728a",
        "terminal.ansi.bright_magenta": "#b189df",
        "terminal.ansi.bright_cyan": "#74c4d0",
        "terminal.ansi.bright_white": "#b4b2c7",
        "created": "#83b2ba",
        "modified": "#d6a765",
        "deleted": "#cd6985",
        "error": "#cd6985",
        "warning": "#d6a765",
        "info": "#416d7f",
        "hint": "#83b2ba",
        "syntax": {
          "comment": { "color": "#73717f", "font_style": "italic" },
          "string": { "color": "#83b2ba" },
          "string.regex": { "color": "#83b2ba" },
          "number": { "color": "#c68784" },
          "constant": { "color": "#c68784" },
          "keyword": { "color": "#958fa7" },
          "function": { "color": "#416d7f" },
          "function.method": { "color": "#416d7f" },
          "type": { "color": "#d6a765" },
          "variable": { "color": "#b4b2c7" },
          "variable.special": { "color": "#cd6985" },
          "property": { "color": "#83b2ba" },
          "operator": { "color": "#83b2ba" },
          "punctuation": { "color": "#73717f" },
          "tag": { "color": "#cd6985" },
          "attribute": { "color": "#83b2ba" },
          "title": { "color": "#416d7f", "font_weight": 700 },
          "link_uri": { "color": "#83b2ba" },
          "link_text": { "color": "#cd6985" }
        }
      }
    }
  ]
}