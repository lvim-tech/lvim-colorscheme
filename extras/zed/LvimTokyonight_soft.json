{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme TokyonightSoft",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme TokyonightSoft",
      "appearance": "dark",
      "style": {
        "background": "#1b1b24",
        "editor.background": "#181820",
        "editor.foreground": "#b2b6c7",
        "editor.line_number": "#5e6274",
        "editor.active_line_number": "#b5b9ca",
        "editor.active_line.background": "#1f202d",
        "editor.gutter.background": "#181820",
        "text": "#b2b6c7",
        "text.muted": "#63677c",
        "text.accent": "#6589d7",
        "border": "#262a3b",
        "surface.background": "#181820",
        "elevated_surface.background": "#181820",
        "element.background": "#1f202d",
        "element.hover": "#262a3b",
        "element.selected": "#262a3b",
        "ghost_element.hover": "#262a3b",
        "drop_target.background": "#262a3b",
        "status_bar.background": "#1f202d",
        "title_bar.background": "#1f202d",
        "toolbar.background": "#181820",
        "tab_bar.background": "#1f202d",
        "tab.active_background": "#181820",
        "tab.inactive_background": "#1f202d",
        "panel.background": "#1f202d",
        "scrollbar.thumb.background": "#262a3b",
        "terminal.background": "#181820",
        "terminal.foreground": "#b2b6c7",
        "terminal.ansi.black": "#191a24",
        "terminal.ansi.red": "#d76479",
        "terminal.ansi.green": "#9dbd7b",
        "terminal.ansi.yellow": "#c5a06b",
        "terminal.ansi.blue": "#4e78d1",
        "terminal.ansi.magenta": "#9470d5",
        "terminal.ansi.cyan": "#60b0de",
        "terminal.ansi.white": "#7f8296",
        "terminal.ansi.bright_black": "#3b4261",
        "terminal.ansi.bright_red": "#ec6d84",
        "terminal.ansi.bright_green": "#a0cf66",
        "terminal.ansi.bright_yellow": "#deab54",
        "terminal.ansi.bright_blue": "#4784f4",
        "terminal.ansi.bright_magenta": "#a479f0",
        "terminal.ansi.bright_cyan": "#49c0fa",
        "terminal.ansi.bright_white": "#b2b6c7",
        "created": "#9dbd7b",
        "modified": "#c5a06b",
        "deleted": "#d76479",
        "error": "#d76479",
        "warning": "#c5a06b",
        "info": "#6589d7",
        "hint": "#60b0de",
        "syntax": {
          "comment": { "color": "#63677c", "font_style": "italic" },
          "string": { "color": "#9dbd7b" },
          "string.regex": { "color": "#60b0de" },
          "number": { "color": "#dd8b5a" },
          "constant": { "color": "#dd8b5a" },
          "keyword": { "color": "#9381b3" },
          "function": { "color": "#6589d7" },
          "function.method": { "color": "#6589d7" },
          "type": { "color": "#c5a06b" },
          "variable": { "color": "#b2b6c7" },
          "variable.special": { "color": "#d76479" },
          "property": { "color": "#60b0de" },
          "operator": { "color": "#60b0de" },
          "punctuation": { "color": "#5e6274" },
          "tag": { "color": "#d76479" },
          "attribute": { "color": "#60b0de" },
          "title": { "color": "#6589d7", "font_weight": 700 },
          "link_uri": { "color": "#60b0de" },
          "link_text": { "color": "#d76479" }
        }
      }
    }
  ]
}