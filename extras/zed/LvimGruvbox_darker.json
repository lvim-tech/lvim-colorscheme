{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme GruvboxDarker",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme GruvboxDarker",
      "appearance": "dark",
      "style": {
        "background": "#191817",
        "editor.background": "#141310",
        "editor.foreground": "#645c54",
        "editor.line_number": "#544c45",
        "editor.active_line_number": "#746c63",
        "editor.active_line.background": "#1e1d1c",
        "editor.gutter.background": "#141310",
        "text": "#645c54",
        "text.muted": "#63584f",
        "text.accent": "#42728b",
        "border": "#282625",
        "surface.background": "#141310",
        "elevated_surface.background": "#141310",
        "element.background": "#1e1d1c",
        "element.hover": "#282625",
        "element.selected": "#282625",
        "ghost_element.hover": "#282625",
        "drop_target.background": "#282625",
        "status_bar.background": "#1e1d1c",
        "title_bar.background": "#1e1d1c",
        "toolbar.background": "#141310",
        "tab_bar.background": "#1e1d1c",
        "tab.active_background": "#141310",
        "tab.inactive_background": "#1e1d1c",
        "panel.background": "#1e1d1c",
        "scrollbar.thumb.background": "#282625",
        "terminal.background": "#141310",
        "terminal.foreground": "#645c54",
        "terminal.ansi.black": "#181716",
        "terminal.ansi.red": "#cb4f4f",
        "terminal.ansi.green": "#75783a",
        "terminal.ansi.yellow": "#af9e6b",
        "terminal.ansi.blue": "#3a6479",
        "terminal.ansi.magenta": "#bb755e",
        "terminal.ansi.cyan": "#527a57",
        "terminal.ansi.white": "#5c544d",
        "terminal.ansi.bright_black": "#63584f",
        "terminal.ansi.bright_red": "#eb4d4d",
        "terminal.ansi.bright_green": "#82861f",
        "terminal.ansi.bright_yellow": "#c3ab58",
        "terminal.ansi.bright_blue": "#2a7390",
        "terminal.ansi.bright_magenta": "#dd7950",
        "terminal.ansi.bright_cyan": "#488b52",
        "terminal.ansi.bright_white": "#645c54",
