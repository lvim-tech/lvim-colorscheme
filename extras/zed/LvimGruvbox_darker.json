          "number": { "color": "#cc7942" },
          "constant": { "color": "#cc7942" },
          "keyword": { "color": "#635d71" },
          "function": { "color": "#42728b" },
          "function.method": { "color": "#42728b" },
          "type": { "color": "#af9e6b" },
          "variable": { "color": "#645c54" },
          "variable.special": { "color": "#cb4f4f" },
          "property": { "color": "#527a57" },
          "operator": { "color": "#527a57" },
          "punctuation": { "color": "#544c45" },
          "tag": { "color": "#cb4f4f" },
          "attribute": { "color": "#527a57" },
          "title": { "color": "#42728b", "font_weight": 700 },
          "link_uri": { "color": "#527a57" },
          "link_text": { "color": "#cb4f4f" }
        }
      }
