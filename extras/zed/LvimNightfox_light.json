{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme NightfoxLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme NightfoxLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#696e75",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#696e75",
        "text.accent": "#4a607e",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#a65c6e",
        "terminal.ansi.green": "#6b8578",
        "terminal.ansi.yellow": "#86774d",
        "terminal.ansi.blue": "#4f6e97",
        "terminal.ansi.magenta": "#725986",
        "terminal.ansi.cyan": "#4e7f80",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#a7bcde",
        "terminal.ansi.bright_red": "#cf5578",
        "terminal.ansi.bright_green": "#64967f",
        "terminal.ansi.bright_yellow": "#98833e",
        "terminal.ansi.bright_blue": "#447cb8",
        "terminal.ansi.bright_magenta": "#8c5aaf",
        "terminal.ansi.bright_cyan": "#3e8f91",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#6b8578",
        "modified": "#86774d",
        "deleted": "#a65c6e",
        "error": "#a65c6e",
        "warning": "#86774d",
        "info": "#4a607e",
        "hint": "#4e7f80",
        "syntax": {
          "comment": { "color": "#696e75", "font_style": "italic" },
          "string": { "color": "#6b8578" },
          "string.regex": { "color": "#4e7f80" },
          "number": { "color": "#a9754b" },
          "constant": { "color": "#a9754b" },
          "keyword": { "color": "#725b95" },
          "function": { "color": "#4a607e" },
          "function.method": { "color": "#4a607e" },
          "type": { "color": "#86774d" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#a65c6e" },
          "property": { "color": "#4e7f80" },
          "operator": { "color": "#4e7f80" },
          "punctuation": { "color": "#696e75" },
          "tag": { "color": "#a65c6e" },
          "attribute": { "color": "#4e7f80" },
          "title": { "color": "#4a607e", "font_weight": 700 },
          "link_uri": { "color": "#4e7f80" },
          "link_text": { "color": "#a65c6e" }
        }
      }
    }
  ]
}