{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme RosepineLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme RosepineLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#7c7a87",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#7c7a87",
        "text.accent": "#578fa6",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#a04a63",
        "terminal.ansi.green": "#5d8086",
        "terminal.ansi.yellow": "#927143",
        "terminal.ansi.blue": "#5e99b2",
        "terminal.ansi.magenta": "#75509c",
        "terminal.ansi.cyan": "#5d8086",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#c5c4d1",
        "terminal.ansi.bright_red": "#c6416e",
        "terminal.ansi.bright_green": "#539099",
        "terminal.ansi.bright_yellow": "#a87b2f",
        "terminal.ansi.bright_blue": "#47aacc",
        "terminal.ansi.bright_magenta": "#8f4ccb",
        "terminal.ansi.bright_cyan": "#539099",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#5d8086",
        "modified": "#927143",
        "deleted": "#a04a63",
        "error": "#a04a63",
        "warning": "#927143",
        "info": "#578fa6",
        "hint": "#5d8086",
        "syntax": {
          "comment": { "color": "#7c7a87", "font_style": "italic" },
          "string": { "color": "#5d8086" },
          "string.regex": { "color": "#5d8086" },
          "number": { "color": "#c0716d" },
          "constant": { "color": "#c0716d" },
          "keyword": { "color": "#8d87a0" },
          "function": { "color": "#578fa6" },
          "function.method": { "color": "#578fa6" },
          "type": { "color": "#927143" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#a04a63" },
          "property": { "color": "#5d8086" },
          "operator": { "color": "#5d8086" },
          "punctuation": { "color": "#7c7a87" },
          "tag": { "color": "#a04a63" },
          "attribute": { "color": "#5d8086" },
          "title": { "color": "#578fa6", "font_weight": 700 },
          "link_uri": { "color": "#5d8086" },
          "link_text": { "color": "#a04a63" }
        }
      }
    }
  ]
}