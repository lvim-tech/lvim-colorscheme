{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme LvimLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme LvimLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#93b6b6",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#789698",
        "text.accent": "#0879a9",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#ac4135",
        "terminal.ansi.green": "#748c50",
        "terminal.ansi.yellow": "#7e652f",
        "terminal.ansi.blue": "#0d8abf",
        "terminal.ansi.magenta": "#bc533c",
        "terminal.ansi.cyan": "#01778a",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#2a9b86",
        "terminal.ansi.bright_red": "#cf3a21",
        "terminal.ansi.bright_green": "#7a9c3d",
        "terminal.ansi.bright_yellow": "#91700f",
        "terminal.ansi.bright_blue": "#0098d2",
        "terminal.ansi.bright_magenta": "#de5123",
        "terminal.ansi.bright_cyan": "#00859a",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#748a4f",
        "modified": "#988b10",
        "deleted": "#f57d76",
        "error": "#ac4135",
        "warning": "#7e652f",
        "info": "#0879a9",
        "hint": "#01778a",
        "syntax": {
          "comment": { "color": "#789698", "font_style": "italic" },
          "string": { "color": "#748c50" },
          "string.regex": { "color": "#01778a" },
          "number": { "color": "#a96400" },
          "constant": { "color": "#a96400" },
          "keyword": { "color": "#1981bd" },
          "function": { "color": "#0879a9" },
          "function.method": { "color": "#0879a9" },
          "type": { "color": "#7e652f" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#ac4135" },
          "property": { "color": "#01778a" },
          "operator": { "color": "#01778a" },
          "punctuation": { "color": "#93b6b6" },
          "tag": { "color": "#ac4135" },
          "attribute": { "color": "#01778a" },
          "title": { "color": "#0879a9", "font_weight": 700 },
          "link_uri": { "color": "#01778a" },
          "link_text": { "color": "#ac4135" }
        }
      }
    }
  ]
}