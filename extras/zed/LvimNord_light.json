{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme NordLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme NordLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#5f646e",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#777d8c",
        "text.accent": "#768ba1",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#935d63",
        "terminal.ansi.green": "#738366",
        "terminal.ansi.yellow": "#87734a",
        "terminal.ansi.blue": "#556a80",
        "terminal.ansi.magenta": "#9e8299",
        "terminal.ansi.cyan": "#61848f",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#93a2bd",
        "terminal.ansi.bright_red": "#bc5966",
        "terminal.ansi.bright_green": "#77935e",
        "terminal.ansi.bright_yellow": "#9b7f3b",
        "terminal.ansi.bright_blue": "#50789c",
        "terminal.ansi.bright_magenta": "#bf84b6",
        "terminal.ansi.bright_cyan": "#5794a5",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#738366",
        "modified": "#87734a",
        "deleted": "#935d63",
        "error": "#935d63",
        "warning": "#87734a",
        "info": "#768ba1",
        "hint": "#61848f",
        "syntax": {
          "comment": { "color": "#777d8c", "font_style": "italic" },
          "string": { "color": "#738366" },
          "string.regex": { "color": "#61848f" },
          "number": { "color": "#b27f6f" },
          "constant": { "color": "#b27f6f" },
          "keyword": { "color": "#8d8497" },
          "function": { "color": "#768ba1" },
          "function.method": { "color": "#768ba1" },
          "type": { "color": "#87734a" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#935d63" },
          "property": { "color": "#61848f" },
          "operator": { "color": "#61848f" },
          "punctuation": { "color": "#5f646e" },
          "tag": { "color": "#935d63" },
          "attribute": { "color": "#61848f" },
          "title": { "color": "#768ba1", "font_weight": 700 },
          "link_uri": { "color": "#61848f" },
          "link_text": { "color": "#935d63" }
        }
      }
    }
  ]
}