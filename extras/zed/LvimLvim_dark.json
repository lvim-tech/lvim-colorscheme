{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme LvimDark",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme LvimDark",
      "appearance": "dark",
      "style": {
        "background": "#1c2125",
        "editor.background": "#181d1f",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#374646",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#20272b",
        "editor.gutter.background": "#181d1f",
        "text": "#5e8888",
        "text.muted": "#4d6263",
        "text.accent": "#0A85B9",
        "border": "#2b343a",
        "surface.background": "#181d1f",
        "elevated_surface.background": "#181d1f",
        "element.background": "#20272b",
        "element.hover": "#2b343a",
        "element.selected": "#2b343a",
        "ghost_element.hover": "#2b343a",
        "drop_target.background": "#2b343a",
        "status_bar.background": "#20272b",
        "title_bar.background": "#20272b",
        "toolbar.background": "#181d1f",
        "tab_bar.background": "#20272b",
        "tab.active_background": "#181d1f",
        "tab.inactive_background": "#20272b",
        "panel.background": "#20272b",
        "scrollbar.thumb.background": "#2b343a",
        "terminal.background": "#181d1f",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#1a1f22",
        "terminal.ansi.red": "#e65e4f",
        "terminal.ansi.green": "#8AA55F",
        "terminal.ansi.yellow": "#edc060",
        "terminal.ansi.blue": "#0974a1",
        "terminal.ansi.magenta": "#c75940",
        "terminal.ansi.cyan": "#018FA6",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#1c7060",
        "terminal.ansi.bright_red": "#f76a5b",
        "terminal.ansi.bright_green": "#90b647",
        "terminal.ansi.bright_yellow": "#fecd65",
        "terminal.ansi.bright_blue": "#0081b4",
        "terminal.ansi.bright_magenta": "#ea5625",
        "terminal.ansi.bright_cyan": "#009db6",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#5f7240",
        "modified": "#a29512",
        "deleted": "#96271a",
        "error": "#e65e4f",
        "warning": "#edc060",
        "info": "#0A85B9",
        "hint": "#018FA6",
        "syntax": {
          "comment": { "color": "#4d6263", "font_style": "italic" },
          "string": { "color": "#8AA55F" },
          "string.regex": { "color": "#018FA6" },
          "number": { "color": "#FF9C2A" },
          "constant": { "color": "#FF9C2A" },
          "keyword": { "color": "#177ab3" },
          "function": { "color": "#0A85B9" },
          "function.method": { "color": "#0A85B9" },
          "type": { "color": "#edc060" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#e65e4f" },
          "property": { "color": "#018FA6" },
          "operator": { "color": "#018FA6" },
          "punctuation": { "color": "#374646" },
          "tag": { "color": "#e65e4f" },
          "attribute": { "color": "#018FA6" },
          "title": { "color": "#0A85B9", "font_weight": 700 },
          "link_uri": { "color": "#018FA6" },
          "link_text": { "color": "#e65e4f" }
        }
      }
    }
  ]
}