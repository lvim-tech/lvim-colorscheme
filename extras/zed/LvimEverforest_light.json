{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme EverforestLight",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme EverforestLight",
      "appearance": "dark",
      "style": {
        "background": "#dfdfdf",
        "editor.background": "#dadada",
        "editor.foreground": "#5e8888",
        "editor.line_number": "#929e8f",
        "editor.active_line_number": "#55a6ab",
        "editor.active_line.background": "#E4E4E4",
        "editor.gutter.background": "#dadada",
        "text": "#5e8888",
        "text.muted": "#8f988a",
        "text.accent": "#5089a6",
        "border": "#e9e9e9",
        "surface.background": "#dadada",
        "elevated_surface.background": "#dadada",
        "element.background": "#E4E4E4",
        "element.hover": "#e9e9e9",
        "element.selected": "#e9e9e9",
        "ghost_element.hover": "#e9e9e9",
        "drop_target.background": "#e9e9e9",
        "status_bar.background": "#E4E4E4",
        "title_bar.background": "#E4E4E4",
        "toolbar.background": "#dadada",
        "tab_bar.background": "#E4E4E4",
        "tab.active_background": "#dadada",
        "tab.inactive_background": "#E4E4E4",
        "panel.background": "#E4E4E4",
        "scrollbar.thumb.background": "#e9e9e9",
        "terminal.background": "#dadada",
        "terminal.foreground": "#5e8888",
        "terminal.ansi.black": "#b6b6b6",
        "terminal.ansi.red": "#c74d4d",
        "terminal.ansi.green": "#7b7e3d",
        "terminal.ansi.yellow": "#8f8156",
        "terminal.ansi.blue": "#5b97b6",
        "terminal.ansi.magenta": "#915a47",
        "terminal.ansi.cyan": "#5c8861",
        "terminal.ansi.white": "#3c7478",
        "terminal.ansi.bright_black": "#676f65",
        "terminal.ansi.bright_red": "#eb4646",
        "terminal.ansi.bright_green": "#888c20",
        "terminal.ansi.bright_yellow": "#a18e47",
        "terminal.ansi.bright_blue": "#42a7d2",
        "terminal.ansi.bright_magenta": "#ae5f3d",
        "terminal.ansi.bright_cyan": "#519a5b",
        "terminal.ansi.bright_white": "#5e8888",
        "created": "#748a4f",
        "modified": "#a27e3e",
        "deleted": "#af5049",
        "error": "#c74d4d",
        "warning": "#8f8156",
        "info": "#5089a6",
        "hint": "#5c8861",
        "syntax": {
          "comment": { "color": "#8f988a", "font_style": "italic" },
          "string": { "color": "#7b7e3d" },
          "string.regex": { "color": "#5c8861" },
          "number": { "color": "#8d522b" },
          "constant": { "color": "#8d522b" },
          "keyword": { "color": "#918c9d" },
          "function": { "color": "#5089a6" },
          "function.method": { "color": "#5089a6" },
          "type": { "color": "#8f8156" },
          "variable": { "color": "#5e8888" },
          "variable.special": { "color": "#c74d4d" },
          "property": { "color": "#5c8861" },
          "operator": { "color": "#5c8861" },
          "punctuation": { "color": "#929e8f" },
          "tag": { "color": "#c74d4d" },
          "attribute": { "color": "#5c8861" },
          "title": { "color": "#5089a6", "font_weight": 700 },
          "link_uri": { "color": "#5c8861" },
          "link_text": { "color": "#c74d4d" }
        }
      }
    }
  ]
}