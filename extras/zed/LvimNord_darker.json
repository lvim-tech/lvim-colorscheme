{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme NordDarker",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme NordDarker",
      "appearance": "dark",
      "style": {
        "background": "#181d23",
        "editor.background": "#14171c",
        "editor.foreground": "#b3bac6",
        "editor.line_number": "#848b98",
        "editor.active_line_number": "#b4bac6",
        "editor.active_line.background": "#1d2128",
        "editor.gutter.background": "#14171c",
        "text": "#b3bac6",
        "text.muted": "#6b717e",
        "text.accent": "#8097af",
        "border": "#252a33",
        "surface.background": "#14171c",
        "elevated_surface.background": "#14171c",
        "element.background": "#1d2128",
        "element.hover": "#252a33",
        "element.selected": "#252a33",
        "ghost_element.hover": "#252a33",
        "drop_target.background": "#252a33",
        "status_bar.background": "#1d2128",
        "title_bar.background": "#1d2128",
        "toolbar.background": "#14171c",
        "tab_bar.background": "#1d2128",
        "tab.active_background": "#14171c",
        "tab.inactive_background": "#1d2128",
        "panel.background": "#1d2128",
        "scrollbar.thumb.background": "#252a33",
        "terminal.background": "#14171c",
        "terminal.foreground": "#b3bac6",
        "terminal.ansi.black": "#171a20",
        "terminal.ansi.red": "#af7177",
        "terminal.ansi.green": "#97ab86",
        "terminal.ansi.yellow": "#cbae72",
        "terminal.ansi.blue": "#6f89a4",
        "terminal.ansi.magenta": "#a58aa0",
        "terminal.ansi.cyan": "#7eaab7",
        "terminal.ansi.white": "#b0b3ba",
        "terminal.ansi.bright_black": "#465062",
        "terminal.ansi.bright_red": "#cd757f",
        "terminal.ansi.bright_green": "#9abd7a",
        "terminal.ansi.bright_yellow": "#e2ba59",
        "terminal.ansi.bright_blue": "#6798c3",
        "terminal.ansi.bright_magenta": "#c48eba",
        "terminal.ansi.bright_cyan": "#70bbcf",
        "terminal.ansi.bright_white": "#b3bac6",
        "created": "#97ab86",
        "modified": "#cbae72",
        "deleted": "#af7177",
        "error": "#af7177",
        "warning": "#cbae72",
        "info": "#8097af",
        "hint": "#7eaab7",
        "syntax": {
          "comment": { "color": "#6b717e", "font_style": "italic" },
          "string": { "color": "#97ab86" },
          "string.regex": { "color": "#7eaab7" },
          "number": { "color": "#ba8574" },
          "constant": { "color": "#ba8574" },
          "keyword": { "color": "#9b93a4" },
          "function": { "color": "#8097af" },
          "function.method": { "color": "#8097af" },
          "type": { "color": "#cbae72" },
          "variable": { "color": "#b3bac6" },
          "variable.special": { "color": "#af7177" },
          "property": { "color": "#7eaab7" },
          "operator": { "color": "#7eaab7" },
          "punctuation": { "color": "#848b98" },
          "tag": { "color": "#af7177" },
          "attribute": { "color": "#7eaab7" },
          "title": { "color": "#8097af", "font_weight": 700 },
          "link_uri": { "color": "#7eaab7" },
          "link_text": { "color": "#af7177" }
        }
      }
    }
  ]
}