{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Lvim Colorscheme MaterialDark",
  "author": "lvim-tech",
  "themes": [
    {
      "name": "Lvim Colorscheme MaterialDark",
      "appearance": "dark",
      "style": {
        "background": "#1e282c",
        "editor.background": "#1a2226",
        "editor.foreground": "#b2c7c7",
        "editor.line_number": "#5e6a70",
        "editor.active_line_number": "#b8bec2",
        "editor.active_line.background": "#222d32",
        "editor.gutter.background": "#1a2226",
        "text": "#b2c7c7",
        "text.muted": "#5e6a70",
        "text.accent": "#618adf",
        "border": "#2a373d",
        "surface.background": "#1a2226",
        "elevated_surface.background": "#1a2226",
        "element.background": "#222d32",
        "element.hover": "#2a373d",
        "element.selected": "#2a373d",
        "ghost_element.hover": "#2a373d",
        "drop_target.background": "#2a373d",
        "status_bar.background": "#222d32",
        "title_bar.background": "#222d32",
        "toolbar.background": "#1a2226",
        "tab_bar.background": "#222d32",
        "tab.active_background": "#1a2226",
        "tab.inactive_background": "#222d32",
        "panel.background": "#222d32",
        "scrollbar.thumb.background": "#2a373d",
        "terminal.background": "#1a2226",
        "terminal.foreground": "#b2c7c7",
        "terminal.ansi.black": "#1b2428",
        "terminal.ansi.red": "#d1676c",
        "terminal.ansi.green": "#a6c974",
        "terminal.ansi.yellow": "#deb05c",
        "terminal.ansi.blue": "#4978da",
        "terminal.ansi.magenta": "#da596e",
        "terminal.ansi.cyan": "#63bbdf",
        "terminal.ansi.white": "#bbc8cd",
        "terminal.ansi.bright_black": "#314549",
        "terminal.ansi.bright_red": "#e76f75",
        "terminal.ansi.bright_green": "#aadb56",
        "terminal.ansi.bright_yellow": "#f7bb2d",
        "terminal.ansi.bright_blue": "#4584fa",
        "terminal.ansi.bright_magenta": "#ef6279",
        "terminal.ansi.bright_cyan": "#3fccfb",
        "terminal.ansi.bright_white": "#b2c7c7",
        "created": "#a6c974",
        "modified": "#deb05c",
        "deleted": "#d1676c",
        "error": "#d1676c",
        "warning": "#deb05c",
        "info": "#618adf",
        "hint": "#63bbdf",
        "syntax": {
          "comment": { "color": "#5e6a70", "font_style": "italic" },
          "string": { "color": "#a6c974" },
          "string.regex": { "color": "#63bbdf" },
          "number": { "color": "#d77c61" },
          "constant": { "color": "#d77c61" },
          "keyword": { "color": "#9e86b0" },
          "function": { "color": "#618adf" },
          "function.method": { "color": "#618adf" },
          "type": { "color": "#deb05c" },
          "variable": { "color": "#b2c7c7" },
          "variable.special": { "color": "#d1676c" },
          "property": { "color": "#63bbdf" },
          "operator": { "color": "#63bbdf" },
          "punctuation": { "color": "#5e6a70" },
          "tag": { "color": "#d1676c" },
          "attribute": { "color": "#63bbdf" },
          "title": { "color": "#618adf", "font_weight": 700 },
          "link_uri": { "color": "#63bbdf" },
          "link_text": { "color": "#d1676c" }
        }
      }
    }
  ]
}